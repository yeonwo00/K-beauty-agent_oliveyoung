OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
PUBLIC_LLM_ENABLED=true
FOLLOW_UP_LLM_ENABLED=true
PRODUCT_REASON_LLM_ENABLED=true
ADMIN_TOKEN=replace-with-a-long-random-token
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///data/k_beauty_agent.sqlite3
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://k-beauty-agent.apps.tossmini.com,https://k-beauty-agent.private-apps.tossmini.com
COOKIE_SAMESITE=lax
SECURE_COOKIES=false
RECOMMEND_RATE_LIMIT_REQUESTS=30
RECOMMEND_RATE_LIMIT_WINDOW_SECONDS=60

# Use curated for stable production behavior. live_keyless enables optional public providers.
PRODUCT_SOURCE=curated
EXTERNAL_CACHE_URL=sqlite:///data/external_product_cache.sqlite3
KRW_PER_USD=1350
OLIVEYOUNG_SNAPSHOT_CSV=data/oliveyoung_snapshot.csv
OLIVEYOUNG_SNAPSHOT_HTML_DIR=data/oliveyoung_snapshots
OPEN_BEAUTY_FACTS_API_URL=https://world.openbeautyfacts.org/cgi/search.pl
COSING_API_URL=https://ec.europa.eu/growth/tools-databases/cosing/api/ingredients
